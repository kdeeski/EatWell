<?xml version="1.0" encoding="utf-8"?>
<!--
  AppWidget provider metadata.
  minWidth/minHeight sized to a 2x1 cell (2 columns × 1 row).
  updatePeriodMillis = 0 means we update manually (via tap or explicit broadcast).
  configure activity is shown when the user adds the widget (for first-run auth).
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="50dp"
    android:resizeMode="horizontal|vertical"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_hydration"
    android:configure="com.eatwell.garminwidget.WidgetConfigActivity"
    android:widgetCategory="home_screen"
    android:description="@string/widget_description"
    android:previewImage="@drawable/ic_water_drop" />
