# Copy this file to .env.local and fill in your values.
# These are set up in Supabase (Project Settings → API) and Anthropic Console.

# Supabase — public keys, safe to include in the mobile bundle
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic API key — stored in Supabase Edge Function secrets, NOT in the app
# Set via: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...
